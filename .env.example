# ── pix-bootstrap · configuración de secretos ─────────────────────────────────
# Copia este archivo a `.env` y rellena los valores. `.env` está en .gitignore
# (NUNCA se comitea). En una instancia Vast también puedes exportar estas
# variables como env vars de la instancia y omitir el archivo `.env`.
#
#   cp .env.example .env && nano .env
# ──────────────────────────────────────────────────────────────────────────────

# ── OBLIGATORIO para descargar modelos de Civitai ────────────────────────────
# Civitai → Account → API Keys. El descargador lo manda como Bearer token.
CIVITAI_TOKEN=

# ── OBLIGATORIO para el túnel permanente (identidad estable del servidor) ─────
# Token del túnel nombrado `comfy` de Cloudflare. El MISMO token en cualquier
# instancia nueva hace que `comfy.vericerbiz.com` vuelva a apuntar a esta caja,
# así el backend Laravel NUNCA cambia. Empieza con "eyJ...".
# Está guardado fuera del repo (ver docs/troubleshooting.md · nunca aquí).
CF_TUNNEL_TOKEN=

# ── OPCIONAL: modelos privados de HuggingFace ────────────────────────────────
HF_TOKEN=

# ── OPCIONAL: acceso SSH directo (además del panel de Vast) ──────────────────
# Clave pública que se añadirá a /root/.ssh/authorized_keys (idempotente).
# Déjalo vacío si gestionas las llaves solo desde el panel de Vast.
SSH_PUBKEY=

# ── OPCIONAL: overrides (normalmente NO hace falta tocarlos) ──────────────────
# Raíz del workspace en la instancia (autodetectado si se deja vacío).
WORKSPACE=
# URL pública del repo, usada por setup/on-start.sh para el clone zero-touch.
PIX_BOOTSTRAP_REPO=https://github.com/LucasRenatoMelgaRios/pix-bootstrap.git
